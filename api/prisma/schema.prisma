generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Students {
  id String @id @default(uuid())
  name String
  classes Int
  absences Int
  value Float

  month Month[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("students")
}

model Month {
  id String @id @default(uuid())
  name Int

  students Students[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
}
